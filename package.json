{
  "name": "3gb_archive",
  "version": "1.0.0",
  "private": true,
  "description": "Discord Archive Viewer monorepo",
  "workspaces": [
    "apps/*",
    "tools/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w apps/web",
    "dev:api": "npm run dev -w apps/api",
    "dev:api:remote": "npm run dev:remote -w apps/api",
    "dev:importer": "npm run dev -w tools/importer",
    "import:sample": "npm run import:sample -w tools/importer",
    "db:migrate:local": "npm run db:migrate:local -w apps/api",
    "db:migrate:remote": "npm run db:migrate:remote -w apps/api",
    "db:check:local": "npm run db:check:local -w apps/api",
    "db:check:remote": "npm run db:check:remote -w apps/api",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "prettier": "^3.6.2"
  }
}
