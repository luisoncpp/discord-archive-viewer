{
  "name": "@archive/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "db:migrate:local": "wrangler d1 execute el-sillon --local --file ../../sql/migrations/0001_init_messages.sql",
    "db:migrate:remote": "wrangler d1 execute el-sillon --remote --file ../../sql/migrations/0001_init_messages.sql",
    "db:check:local": "wrangler d1 execute el-sillon --local --command \"SELECT name FROM sqlite_master WHERE type='table' ORDER BY name;\"",
    "db:check:remote": "wrangler d1 execute el-sillon --remote --command \"SELECT name FROM sqlite_master WHERE type='table' ORDER BY name;\""
  },
  "dependencies": {
    "hono": "^4.10.6",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260313.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.7",
    "wrangler": "^4.61.0"
  }
}
