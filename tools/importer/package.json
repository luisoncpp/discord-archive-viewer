{
  "name": "@archive/importer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "import": "tsx src/index.ts",
    "import:sample": "tsx src/index.ts --csv ../../sillon.csv --max-rows 5000",
    "build": "tsc -p tsconfig.json",
    "lint": "tsc --noEmit",
    "test": "vitest run --exclude dist/**"
  },
  "dependencies": {
    "csv-parse": "^5.5.6",
    "iconv-lite": "^0.6.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.7"
  }
}
